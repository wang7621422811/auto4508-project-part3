        </mxCell>
        <mxCell id="76" value="drawLidar()&#xa;cyan scatter (toggle)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=9;" vertex="1" parent="1">
