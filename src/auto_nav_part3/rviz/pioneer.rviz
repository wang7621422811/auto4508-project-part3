          Show Trail: false
          Value: true
        cam_optical_link:
          Alpha: 1
          Show Axes: false
          Show Trail: false
        chassis:
          Alpha: 1
          Show Axes: false
          Show Trail: false
          Value: true
        front_left_axle:
          Alpha: 1
